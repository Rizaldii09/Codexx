# Pilih provider: local, anthropic/claude, deepseek, glm/zai/zhipu, atau openai-compatible
AI_PROVIDER=local
AI_MODEL=claude-3-5-sonnet-latest
LLM_MAX_TOKENS=4096

# Claude / Anthropic Messages API
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# DeepSeek OpenAI-compatible Chat Completions API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# GLM / Zhipu BigModel OpenAI-compatible Chat Completions API
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Custom OpenAI-compatible provider/proxy, e.g. OpenRouter, local gateway, self-hosted model
COMPATIBLE_API_KEY=
COMPATIBLE_BASE_URL=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_EMAIL_TO=
RAG_DB_PATH=.codexx/rag.sqlite
